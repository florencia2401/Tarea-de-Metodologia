const readline = require("readline");

const alumnos = [
  { id: 1, nombre: "Martina Concha", email: "Martina.Concha2301@alumnos.ubiobio.cl", seccion: "2" },
  { id: 2, nombre: "Jose Carrillo", email: "Jose.carrillo2401@alumnos.ubiobio.cl", seccion: "1" },
  { id: 3, nombre: "Renato Quezada", email: "Renato.quezada2401@alumnos.ubiobio.cl", seccion: "1" },
];

let sig_Id = 4;



// funcion para Listar alumnos
function listar_alumnos() {
  return alumnos;
}


// funcion para actualizar alumno por id
function actualizar_el_alumno(id, datos_actualizados) {

  const alumno = alumnos.find((a) => a.id === id);

  if(!alumno){
    return null;
  }

  if(datos_actualizados.nombre !== undefined){
    alumno.nombre = datos_actualizados.nombre;
  }

  if(datos_actualizados.email !== undefined){
    alumno.email = datos_actualizados.email;
  }

  if(datos_actualizados.seccion !== undefined){
    alumno.seccion = datos_actualizados.seccion;
  }

  return alumno;
}
// funcion para crear alumno 
function crear_alumno(nombre, email, seccion) {
  const Alumnonuevo = {
    id: sig_Id,
    nombre,
    email,
    seccion,
  };

  alumnos.push(Alumnonuevo);
  sig_Id++;

  return Alumnonuevo;
}
// funcion para eliminar alumno por id
function eliminar_los_Alumno(id){
  const indice = alumnos.findIndex((a) => a.id === id);

  if(indice === -1){
    return false;
  }


  alumnos.splice(indice, 1);
  return true;
}
// funcion para poder obtener alumno por id
function obtener_alumno_por_Id(id) {

  return alumnos.find((alumno) => alumno.id === id);
}

// parte extra
function buscar_el_alumnos_seccion(seccion) {
  return alumnos.filter((a) => a.seccion === seccion);
}

