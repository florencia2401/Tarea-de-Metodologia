const rl = readline.createInterface({
  input: process.stdin,
  output: process.stdout,
});

function preguntar(texto) {
  return new Promise((resolve) => {
    rl.question(texto, (respuesta) => {
      resolve(respuesta.trim());
    });
  });
}

function toNumber(valor) {
  const numero = Number(valor);
  return Number.isNaN(numero) ? null : numero;
}

function mostrarmenu() {
  console.log("\n----- MENU ------");
  console.log("1) Listar alumnos");
  console.log("2) Crear alumno nuevo");
  console.log("3) Buscar alumno por id");
  console.log("4) Editar alumno");
  console.log("5) Eliminar alumno");
  console.log("0) Salir");
}

async function ejecutarmenu() {
  let continuar = true;

  while (continuar) {
    mostrarmenu();
    const opcion = await preguntar("Selecciona una opcion: ");

    switch (opcion) {
      case "1": {
        const lista = listar_alumnos();
        console.log("\n---LISTADO ---");
        console.table(lista);
        break;
      }

      case "2": {
        const nombre = await preguntar("Nombre: ");
        const email = await preguntar("Email: ");
        const seccion = await preguntar("Seccion: ");

        const Alumnonuevo= crear_alumno(nombre, email, seccion);
        console.log("Alumno creado:", Alumnonuevo);
        break;
      }

      case "3": {
        const id = toNumber(await preguntar("ID a buscar: "));
        if (id === null) {
          console.log("ID invalido.");
          break;
        }

        const alumno = obtener_alumno_por_Id(id);
        console.log(
          alumno ? "Se entro al alumno:" : "No existe ese alumno:",
          alumno
        );
        break;
      }

      case "4": {
        const id = toNumber(await preguntar("ID a editar: "));
        if (id === null) {
          console.log("ID invalido.");
          break;
        }

        const nombre = await preguntar("Nuevo nombre: ");
        const email = await preguntar("Nuevo email: ");
        const seccion = await preguntar("Nueva seccion: ");

        const datos_actualizados = {};
        if (nombre) datos_actualizados.nombre = nombre;
        if (email) datos_actualizados.email = email;
        if (seccion) datos_actualizados.seccion = seccion;

        const actualizado = actualizar_alumno(id, datos_actualizados);

        console.log(
          actualizado ? "Alumno actualizado:" : "No existe ese alumno:",
          actualizado
        );
        break;
      }

      case "5": {
        const id = toNumber(await preguntar("ID a eliminar: "));
        if (id === null) {
          console.log("ID invalido.");
          break;
        }

        const eliminado = eliminar_alumno(id);
        console.log(eliminado ? "Alumno eliminado." : "No existe ese id.");
        break;
      }

      case "0": {
        continuar = false;
        console.log("ya salio del programa");
        break;
      }

      default: {
        console.log("Opcion no valida.");
      }
    }
  }

  rl.close();
}

ejecutarmenu();
